---
interface Props {
    title: string;
    valueId: string;
    defaultValue: string;
    subtitle: string;
}

const { title, valueId, defaultValue, subtitle } = Astro.props;
---
<div class="col-md-4">
    <div class="card text-bg-success h-100 shadow-sm border-0">
        <div class="card-body text-center d-flex flex-column justify-content-center py-4">
            <h6 class="text-uppercase mb-2 fw-semibold">{title}</h6>
            <h2 id={valueId} class="mb-0 fw-bold display-6">{defaultValue}</h2>
            <small class="mt-2 opacity-75">{subtitle}</small>
        </div>
    </div>
</div>