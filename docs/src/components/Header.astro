<header class="pb-3 mb-4 border-bottom d-flex flex-wrap align-items-center justify-content-between gap-3">
    <div class="d-flex align-items-center">
        <img src="/img/icon.png?v=1" alt="Green Grid Icon" class="me-3" style="width: 60px; height: auto;">
        <div>
            <h1 class="display-5 fw-bold text-body-emphasis mb-0">
                Green Grid Simulation
                <span class="text-success">Results Dashboard</span>
            </h1>
            <p class="fs-5 text-secondary mb-0">Interactive analysis of neighborhood energy consumption, solar generation, and battery storage.</p>
        </div>
    </div>

    <div>
        <button id="theme-toggle" class="btn btn-outline-secondary d-flex align-items-center gap-2">
            <span id="theme-icon">🌓</span>
            <span id="theme-text">Cambiar Tema</span>
        </button>
    </div>
