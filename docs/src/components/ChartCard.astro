---
interface Props {
    title: string;
    chartId: string;
    columnClass?: string;
}

const { title, chartId, columnClass = "col-md-6" } = Astro.props;
---
<div class={columnClass}>
    <div class="card h-100 shadow-sm border-0">
        <div class="card-body p-4">
            <h5 class="card-title text-secondary mb-2 fw-bold">{title}</h5>
            
            <slot name="header-text" />
            
            <div id={chartId} class="w-100 overflow-auto text-center mt-3"></div>
            
            <div class="mt-4 pt-3 border-top">
                <p class="text-secondary small mb-0">
                    <slot name="footer-text" />
                </p>
            </div>
        </div>
    </div>
</div>